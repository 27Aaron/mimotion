# 数据库
DATABASE_URL=./data/mimotion.db

# 加密（32字节随机字符串，hex编码64字符）
ENCRYPTION_KEY=your-64-char-hex-encoded-32-bytes-key-here

# JWT（32字节随机字符串）
JWT_SECRET=your-64-char-hex-encoded-32-bytes-secret-here

# Bark
BARK_URL=https://api.day.app

# 初始管理员（仅首次迁移有效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# Telegram Bot（可选，用于推送通知）
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
