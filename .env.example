# 数据库
DATABASE_URL=./data/mimotion.db

# 加密（32字节随机字符串，hex编码64字符）
ENCRYPTION_KEY=your-64-char-hex-encoded-32-bytes-key-here
# 轮换密钥时，将旧密钥放在这里；多个旧密钥用逗号分隔
# ENCRYPTION_KEY_PREVIOUS=previous-64-char-hex-key

# JWT（32字节随机字符串）
JWT_SECRET=your-64-char-hex-encoded-32-bytes-secret-here

# 初始管理员（仅首次迁移有效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# 站点公开地址（用于登录跳转和 Bark 推送图标，反向代理部署时建议配置）
# APP_URL=https://your-domain.com

# 进程角色：all 同时运行 Web 和 Worker，也可拆成 web / worker 两个进程
MIMOTION_ROLE=all
# Web 监听地址；使用专用变量以避免和系统 HOSTNAME 冲突
MIMOTION_HOST=0.0.0.0
WORKER_CONCURRENCY=3
