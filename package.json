{
  "name": "mimotion",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node scripts/start.mjs --dev",
    "setup": "node scripts/init-db.mjs",
    "build": "next build && npm run build:worker",
    "build:worker": "esbuild worker/main.ts --bundle --platform=node --format=esm --target=node22 --sourcemap --outfile=.worker/worker.mjs --external:better-sqlite3",
    "start": "node scripts/start.mjs",
    "start:web": "next start",
    "start:worker": "node .worker/worker.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/unit/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/init-db.mjs",
    "db:studio": "drizzle-kit studio",
    "db:init-admin": "npx tsx scripts/init-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/postcss": "^4.2.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.6",
    "shadcn": "^4.13.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "esbuild": "$esbuild"
  }
}
